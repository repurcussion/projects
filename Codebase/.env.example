# ============================================================
# CV Sorting using LLMs – Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored – never commit real API keys.
# ============================================================

# ----------------------------------------------------------
# LLM Provider (auto | ollama | openai | hf)
# auto = OpenAI API first, then Ollama, then HuggingFace
# ----------------------------------------------------------
LLM_PROVIDER=auto

# ----------------------------------------------------------
# OpenAI (required only when provider=openai or provider=auto)
# Get your key: https://platform.openai.com/api-keys
# ----------------------------------------------------------
OPENAI_API_KEY=sk-...

# Optional: override specific OpenAI model names
# OPENAI_PARSER_MODEL=gpt-3.5-turbo
# OPENAI_SCORER_MODEL=gpt-4o

# ----------------------------------------------------------
# Ollama (local) – only if provider=ollama or provider=auto
# Default URL assumes Ollama running on localhost:11434
# ----------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# PARSER_MODEL=gemma:2b
# SCORER_MODEL=llama3

# ----------------------------------------------------------
# HuggingFace (local) – only if provider=hf or provider=auto
# Model is downloaded automatically on first run.
# ----------------------------------------------------------
# HF_PARSER_MODEL=google/flan-t5-base
# HF_MAX_INPUT_TOKENS=512
# HF_MAX_NEW_TOKENS=384
